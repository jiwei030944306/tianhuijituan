{
  "name": "zycloud-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.{ts,tsx,js,vue}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,js,vue}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,json}\""
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "@types/jszip": "^3.4.0",
    "axios": "^1.6.0",
    "element-plus": "^2.5.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.28",
    "lucide-vue-next": "^0.563.0",
    "pinia": "^3.0.4",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.24",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^1.8.0"
  }
}
